NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_API_BASE_URL=/api
# Server-side proxy target. Leave unset to use the built-in defaults:
# - localhost -> http://localhost:4000
# - Vercel -> http://ssh.gsmsv.site:25124/api
# - VM Docker deploy -> http://backend:4000
# Override this only when you need a different absolute upstream API base URL.
API_PROXY_TARGET=http://localhost:4000
NEXT_PUBLIC_GITHUB_CLIENT_ID=your-github-client-id
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=https://example.com/auth/callback/google
