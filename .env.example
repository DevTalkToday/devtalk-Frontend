NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_API_BASE_URL=/api
# Server-side proxy target. Local dev can use http://localhost:4000.
# For Vercel -> VM proxying, set this to the full VM API base such as http://ssh.gsmsv.site:25124/api.
API_PROXY_TARGET=http://localhost:4000
NEXT_PUBLIC_SITE_URL=https://example.com
GOOGLE_SITE_VERIFICATION=your-google-site-verification-token
NEXT_PUBLIC_GITHUB_CLIENT_ID=your-github-client-id
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=https://example.com/auth/callback/google
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-your-publisher-id
NEXT_PUBLIC_ADSENSE_TEST_SLOT=your-display-ad-slot-id
